{% comment %}
  This section is used in the product template to render product page with
  media, content, and add-to-cart form.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/product
{% endcomment %}

<div class="jsd-product-container">
  <div class="jsd-product-main">
    <!-- Gallery -->
    <div class="jsd-product-media">
      {% for image in product.images %}
        <div class="jsd-media-item">
          <img src="{{ image | img_url: 'master' }}" alt="{{ image.alt }}" class="jsd-image">
        </div>
      {% endfor %}
    </div>

    <!-- Info -->
    <div class="jsd-product-details">
      <div class="jsd-product-header">
        <p class="jsd-eyebrow">{{ product.vendor | upcase }}</p>
        <h1 class="jsd-product-title">{{ product.title | upcase }}</h1>
        <p class="jsd-product-price">{{ product.price | money }}</p>
      </div>

      <div class="jsd-product-description">
        {{ product.description }}
      </div>

      <div class="jsd-product-form-wrapper">
        {% form 'product', product %}
          {% assign current_variant = product.selected_or_first_available_variant %}

          <div class="jsd-form-group">
            <label for="variant-select">SELECT VARIANT</label>
            <select name="id" id="variant-select" class="jsd-select">
              {% for variant in product.variants %}
                <option value="{{ variant.id }}" {% if variant == current_variant %}selected="selected"{% endif %}>
                  {{ variant.title }} — {{ variant.price | money }}
                </option>
              {% endfor %}
            </select>
          </div>

          <div class="jsd-form-group">
            <label for="quantity">QUANTITY</label>
            <input type="number" name="quantity" id="quantity" min="1" value="1" class="jsd-input">
          </div>

          <div class="jsd-actions">
            <button type="submit" class="jsd-btn-primary">[ ADD TO BAG ]</button>
            {{ form | payment_button }}
          </div>
        {% endform %}
      </div>
    </div>
  </div>
</div>

<style>
.jsd-product-container {
  padding: 100px 40px;
  max-width: 1400px;
  margin: 0 auto;
  font-family: 'Inter', sans-serif;
}

.jsd-product-main {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 80px;
  align-items: start;
}

.jsd-product-media {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.jsd-media-item {
  background: #f9f9f9;
  padding: 40px;
  border: 1px solid rgba(0,0,0,0.05);
}

.jsd-image {
  width: 100%;
  height: auto;
  object-fit: contain;
}

.jsd-product-details {
  position: sticky;
  top: 140px;
}

.jsd-eyebrow {
  font-size: 10px;
  letter-spacing: 0.5em;
  font-weight: 800;
  opacity: 0.3;
  margin-bottom: 20px;
}

.jsd-product-title {
  font-family: 'Montserrat', sans-serif !important;
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 800;
  letter-spacing: -0.05em;
  line-height: 0.9;
  margin-bottom: 20px;
}

.jsd-product-price {
  font-size: 24px;
  font-weight: 700;
  margin-bottom: 40px;
}

.jsd-product-description {
  font-size: 15px;
  line-height: 1.6;
  opacity: 0.8;
  margin-bottom: 60px;
  color: #333;
}

.jsd-form-group {
  margin-bottom: 24px;
}

.jsd-form-group label {
  display: block;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.2em;
  margin-bottom: 10px;
  opacity: 0.5;
}

.jsd-select, .jsd-input {
  width: 100%;
  padding: 15px;
  border: 1.5px solid #000;
  border-radius: 0;
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  appearance: none;
  background: #fff;
}

.jsd-actions {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 40px;
}

.jsd-btn-primary {
  background: #000;
  color: #fff;
  padding: 20px;
  border: none;
  font-weight: 800;
  letter-spacing: 0.3em;
  cursor: pointer;
  transition: all 0.3s ease;
}

.jsd-btn-primary:hover {
  background: #333;
}

@media (max-width: 1024px) {
  .jsd-product-main {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .jsd-product-details {
    position: static;
  }
}
</style>

{% schema %}
{
  "name": "t:general.product",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
