{% schema %}
{
  "name": "JSD HoloCard Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Choose Your Design."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_count",
      "min": 4,
      "max": 12,
      "step": 4,
      "label": "Number of products",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "JSD HoloCard Grid"
    }
  ]
}
{% endschema %}

<section class="jsd-grid-section">
  <div class="jsd-grid-header">
    <h2 class="jsd-grid-title">{{ section.settings.title }}</h2>
  </div>

  <div class="jsd-grid">
    {% assign collection = section.settings.collection %}
    {% if collection != blank and collection.products_count > 0 %}
      {% for product in collection.products limit: section.settings.product_count %}
        {% assign rarity_index = forloop.index | prepend: '00' | slice: -3, 3 %}
        {% render 'product-card-holo', product: product, rarity: rarity_index %}
      {% endfor %}
    {% else %}
      {% comment %} 
        Show high-fidelity placeholders matching the prototype designs 
      {% endcomment %}
      {% assign placeholder_designs = "THE SNEAKER,DIVINE DNA,INJOY,IDENTITY (ID)" | split: ',' %}
      {% assign placeholder_images = "SneakerBlack.png,DNABlack.png,InjoyFrontBlack.png,IDBlack.png" | split: ',' %}
      {% assign placeholder_rarities = "001,002,003,004" | split: ',' %}
      
      {% for i in (0..3) %}
        <div class="jsd-card-container">
          <div class="jsd-card is-placeholder">
            <!-- FRONT -->
            <div class="jsd-card-face jsd-card-front">
                <div class="jsd-card-image-wrapper">
                    <img src="{{ placeholder_images[i] | asset_url }}" alt="{{ placeholder_designs[i] }}" class="jsd-card-image">
                </div>
                <div class="jsd-card-rarity">
                  <span>◆ {{ placeholder_rarities[i] }}</span>
                </div>
            </div>
            <!-- BACK -->
            <div class="jsd-card-face jsd-card-back">
                <div class="jsd-card-back-header">
                    <p class="jsd-card-eyebrow">Jehovah Sneaky Designs</p>
                    <h2 class="jsd-card-title">{{ placeholder_designs[i] }}</h2>
                </div>
                <div class="jsd-card-back-content">
                  <p class="jsd-card-description">High-fidelity prototype design for JSD. Ported to Shopify theme.</p>
                </div>
                <div class="jsd-card-back-footer">
                    <button class="jsd-card-btn">[ View Details ]</button>
                    <div class="jsd-card-back-nav">
                        <button class="jsd-card-back-close" type="button">← [ Go Back ]</button>
                    </div>
                </div>
            </div>
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>
</section>

<style>
.jsd-grid-section {
  position: relative;
  z-index: 2;
  background: #fff;
  padding: 100px 40px;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.jsd-grid-header {
  margin-bottom: 60px;
  text-align: center;
}

.jsd-grid-title {
  font-size: clamp(2rem, 5vw, 4rem);
  font-weight: 800;
  letter-spacing: -0.05em;
  text-transform: uppercase;
}

.jsd-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20px;
  width: 100%;
}

@media (max-width: 768px) {
    .jsd-grid {
        flex-direction: column;
        align-items: center;
    }
}
</style>
