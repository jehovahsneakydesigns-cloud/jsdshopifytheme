{% schema %}
{
  "name": "JSD Parallax Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Jehovah Sneaky Designs"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Hero Title",
      "default": "When Jesus Sneaks Up On Ya..."
    }
  ],
  "presets": [
    {
      "name": "JSD Parallax Hero"
    }
  ]
}
{% endschema %}

<section class="jsd-hero-parallax">
  <p class="jsd-hero-eyebrow">{{ section.settings.eyebrow | upcase }}</p>
  <h1 class="jsd-grid-title">{{ section.settings.title | upcase }}</h1>
  
  <div class="jsd-hero-scroll">
    SCROLL
  </div>
</section>

<style>
.jsd-hero-parallax {
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: #fff;
    position: sticky;
    top: 0;
    z-index: 10;
    text-align: center;
    padding: 0 20px;
}

.jsd-hero-eyebrow {
    font-size: clamp(10px, 2vw, 14px);
    letter-spacing: 0.6em;
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: 2rem;
    opacity: 0.6;
    font-family: 'Montserrat', sans-serif !important;
}

.jsd-hero-title {
    font-size: clamp(3rem, 12vw, 8rem);
    line-height: 0.85;
    font-weight: 800;
    margin: 0;
    letter-spacing: -0.05em;
    font-family: 'Montserrat', sans-serif !important;
}

.jsd-hero-scroll {
    position: absolute;
    bottom: 40px;
    font-size: 10px;
    letter-spacing: 0.4em;
    font-weight: 700;
    opacity: 0.3;
    animation: bounce 1.4s infinite ease-in-out;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(10px); }
}
</style>
