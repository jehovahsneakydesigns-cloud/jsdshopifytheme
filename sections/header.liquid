<nav class="jsd-navbar">
  <div class="jsd-navbar-grid">
    <!-- Left links -->
    <div class="jsd-nav-links jsd-nav-left">
      <a href="/" class="jsd-nav-link">HOME</a>
      <a href="/collections/all" class="jsd-nav-link">SHOP</a>
    </div>

    <!-- Center logo -->
    <div class="jsd-nav-logo">
      <a href="/">
        <img
          src="{{ 'SneakerBlack.png' | asset_url }}"
          alt="JSD Logo"
          class="jsd-logo-img"
          loading="lazy"
          width="auto"
          height="32"
        >
      </a>
    </div>

    <!-- Right links -->
    <div class="jsd-nav-links jsd-nav-right">
      <a href="#" class="jsd-nav-link">VIDEOS</a>
      <a href="#" class="jsd-nav-link">STORIES</a>
    </div>
  </div>
</nav>

<style>
.jsd-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 40;
  background: transparent;
  pointer-events: none;
}

.jsd-navbar-grid {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  padding: 20px 40px;
  pointer-events: auto;
}

.jsd-nav-links {
  display: flex;
  align-items: center;
  gap: 28px;
}

.jsd-nav-left {
  justify-content: flex-end;
  padding-right: 40px;
}

.jsd-nav-right {
  justify-content: flex-start;
  padding-left: 40px;
}

.jsd-nav-link {
  position: relative;
  text-decoration: none;
  font-size: 10px;
  tracking: 0.35em;
  text-transform: uppercase;
  font-weight: 800;
  color: #000;
  transition: color 0.3s;
}

.jsd-nav-link::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: -2px;
  height: 1px;
  width: 0;
  background: #000;
  transition: width 0.3s ease-in-out;
}

.jsd-nav-link:hover::after {
  width: 100%;
}

.jsd-logo-img {
  height: 32px;
  width: auto;
  object-fit: contain;
  display: block;
}

@media (max-width: 768px) {
  .jsd-nav-links {
    display: none;
  }
  .jsd-navbar-grid {
    grid-template-columns: 1fr;
    justify-content: center;
    padding: 16px 20px;
  }
}
</style>

